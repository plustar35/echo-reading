{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.codex/hooks/progress-reminder-codex.sh\"",
            "statusMessage": "Checking reading progress reminder",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.codex/hooks/insight-reminder-codex.sh\"",
            "statusMessage": "Checking insight reminder",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
